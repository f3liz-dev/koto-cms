# GitHub Configuration
GITHUB_BOT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main

# Session Security
SESSION_SECRET=your-random-32-character-secret-here-change-this
SESSION_TTL_HOURS=8
SESSION_TOKEN_VERSION=1

# Editor Allowlist (comma-separated Fediverse handles)
DOCUMENT_EDITORS=@alice@misskey.io,@bob@calckey.social
# OR use a file (one handle per line)
# DOCUMENT_EDITORS_FILE=/path/to/editors.txt

# MiAuth Configuration
MIAUTH_CALLBACK_URL=http://localhost:3000/miauth/callback
APP_NAME=f3liz CMS

# Server Configuration
CMS_PORT=3000
CMS_HOST=0.0.0.0

# Frontend Configuration (required for production)
# Object Storage URL where frontend assets are hosted
FRONTEND_URL=https://objectstorage.us-ashburn-1.oraclecloud.com/n/namespace/b/bucket/o

# OCI Configuration (for deployment)
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx
OCI_NAMESPACE=your-namespace
OCI_BUCKET_NAME=f3liz-cms-frontend
OCI_APP_NAME=f3liz-cms-app
